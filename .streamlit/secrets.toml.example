# .streamlit/secrets.toml — Configuración para Streamlit Cloud
#
# Instrucciones:
#   1. En Streamlit Cloud: copiar el contenido relevante al panel
#      "Settings → Secrets" de tu app (sin las líneas comentadas).
#   2. En local: copiar este archivo como .streamlit/secrets.toml
#      y completar los valores. El archivo real NUNCA va a git.
#
# Todas las variables tienen valores por defecto razonables.
# Solo incluir en secrets las que necesitás sobreescribir.

# ─── Rutas ────────────────────────────────────────────────────────────────────
# En Streamlit Cloud el filesystem es efímero (se borra al reiniciar).
# Para producción se recomienda apuntar a /tmp para evitar escribir
# en el filesystem montado del repo.
DB_PATH = "/tmp/energy_uy.sqlite"

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL = "WARNING"

# ─── Fuentes de datos ────────────────────────────────────────────────────────
# Las URLs son públicas y no requieren credenciales.
# Solo sobreescribir si ADME o UTE cambian sus dominios.
# ADME_BASE_URL     = "https://adme.com.uy"
# ADME_GPF_BASE_URL = "https://pronos.adme.com.uy"
# UTE_BASE_URL      = "https://apps.ute.com.uy"

# ─── HTTP ─────────────────────────────────────────────────────────────────────
# HTTP_TIMEOUT = "45"
# HTTP_USER_AGENT = "Mozilla/5.0 (compatible; energy-uy-pipeline/0.1)"

# ─── Estado de fuentes ───────────────────────────────────────────────────────
# UTE Bajadas está deshabilitada. Cambiar a "true" cuando vuelva a estar online.
UTE_BAJADAS_ENABLED = "false"

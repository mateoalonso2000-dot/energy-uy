# ─── Configuración general ───────────────────────────────────────────────────
# Copiar este archivo como .env y completar los valores reales.
# El archivo .env NUNCA debe subirse a git.

# Ruta a la base de datos SQLite (relativa a la raíz del proyecto)
DB_PATH=data/db/energy_uy.sqlite

# Directorio de salida para gráficos y reportes
OUTPUT_DIR=outputs

# ─── Logging ─────────────────────────────────────────────────────────────────
# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─── ADME ────────────────────────────────────────────────────────────────────
# URL base de ADME (no modificar salvo que cambie el dominio)
ADME_BASE_URL=https://adme.com.uy

# ─── UTE ─────────────────────────────────────────────────────────────────────
UTE_BASE_URL=https://apps.ute.com.uy

# ─── Estado de fuentes ───────────────────────────────────────────────────────
# UTE Bajadas está caída. Cambiar a true cuando vuelva a estar operativa.
UTE_BAJADAS_ENABLED=false

# ─── Opcionales ──────────────────────────────────────────────────────────────
# Timeout en segundos para requests HTTP
HTTP_TIMEOUT=30

# User-agent para requests (algunos servidores bloquean requests sin UA)
HTTP_USER_AGENT=Mozilla/5.0 (compatible; energy-uy-pipeline/0.1)
